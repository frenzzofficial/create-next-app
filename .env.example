# Committed, no real values — the Zod schemas in packages/env are the
# actual source of truth; this file just documents them for onboarding.
# Copy to .env.local and fill in real values for local development.

# ---------------------------------------------------------------------------
# client.env.ts — public, shipped to the browser. Every key MUST start with
# NEXT_PUBLIC_ or Next.js won't inline it into the client bundle.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=create-next-app
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_API_PATH=/api

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=create-next-app
NEXT_PUBLIC_SITE_TITLE=top 1% Frontend Template of 2026
NEXT_PUBLIC_LOGO_URL=http://localhost:3000/logo.png
NEXT_PUBLIC_OG_IMAGE_URL=http://localhost:3000/og-image.png
NEXT_PUBLIC_SITE_DESCRIPTION=Future-ready 2026 frontend template for creating robust, enterprise-level web apps.

NEXT_PUBLIC_CLIENT_ORIGIN=http://localhost:7164
NEXT_PUBLIC_CLIENT_API_ORIGIN=http://localhost:7164/app

# ---------------------------------------------------------------------------
# app.env.ts — server-only, general config. Never prefix these with
# NEXT_PUBLIC_ — they must not reach the browser bundle.
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ---------------------------------------------------------------------------
# auth.env.ts — server-only, highest sensitivity. Consumed by the auth
# service layer only (Stage 11). JWT_SECRET has no default on purpose —
# generate a real 32+ character secret per environment, never reuse one.
# ---------------------------------------------------------------------------
JWT_SECRET=
SESSION_COOKIE_NAME=session
REFRESH_TOKEN_TTL_DAYS=30

# ---------------------------------------------------------------------------
# user.env.ts — public placeholder/demo user, used to hydrate UI previews
# (avatar cards, showcase pages) without a real session behind them.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_DEFAULT_USER_ID=default-user-1
NEXT_PUBLIC_DEFAULT_USER_FULLNAME=John Doe
NEXT_PUBLIC_DEFAULT_USER_EMAIL=johndoe@gmail.com
NEXT_PUBLIC_DEFAULT_USER_PASSWORD=Johndoe#1234
NEXT_PUBLIC_DEFAULT_USER_AVATAR_URL=http://localhost:3000/avatars/default-user.png
NEXT_PUBLIC_DEFAULT_USER_ROLE=USER
NEXT_PUBLIC_DEFAULT_USER_STATUS=ACTIVE
